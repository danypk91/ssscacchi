---
import BaseLayout from '../layouts/BaseLayout.astro';

const linkCategories = [
  {
    title: 'Federazioni',
    links: [
      { name: 'FSI – Federazione Scacchistica Italiana', url: 'https://www.federscacchi.it/' },
      { name: 'Comitato Regionale Liguria Scacchi', url: 'https://www.liguriascacchi.it/' },
      { name: 'FIDE – World Chess Federation', url: 'https://www.fide.com/' },
    ],
  },
  {
    title: 'Circoli Genovesi e Liguri',
    links: [
      { name: 'Circolo Scacchistico "Luigi Centurini"', url: 'https://www.centurini.it/' },
      { name: 'Circolo Scacchistico "Filippo Merlino" – Sestri Ponente', url: 'https://www.scacchigenovamerlino.altervista.org' },
      { name: 'Scacchi Ruta – Ruta di Camogli', url: 'https://scacchiruta.altervista.org/' },
      { name: 'Circolo Scacchistico Sammargaritese', url: 'https://www.scacchidisanta.it/' },
    ],
  },
  {
    title: 'Strumenti e Piattaforme',
    links: [
      { name: 'VeSuS – Gestione tornei e iscrizioni', url: 'https://vesus.org/' },
      { name: 'Il kit dell\'arbitro – Calcolo ELO', url: 'https://arbitri.lombardiascacchi.com/arb_calcolo_elo.html' },
    ],
  },
  {
    title: 'Risorse Scacchistiche',
    links: [
      { name: 'Le due Torri', url: 'https://www.scacco.it' },
      { name: 'Scacchi che passione!', url: 'https://scacchichepassione.altervista.org/' },
      { name: 'Classifica mondiale Top 50', url: 'https://www.2700chess.com/' },
      { name: 'Uno Scacchista – Blog di analisi', url: 'https://unoscacchista.com/' },
    ],
  },
  {
    title: 'Organizzazione',
    links: [
      { name: 'U.S. ACLI Santa Sabina', url: 'https://www.santasabina.org/start.htm' },
      { name: 'U.S. ACLI Santa Sabina – Facebook', url: 'https://www.facebook.com/santa.sabina.92/?locale=it_IT' },
    ],
  },
];
---

<BaseLayout title="Link" description="Link utili a federazioni, circoli, strumenti e risorse scacchistiche.">
  <section class="page-header">
    <div class="page-header-bg" aria-hidden="true"></div>
    <div class="page-header-decor" aria-hidden="true">&#9816;</div>
    <div class="container">
      <h1>Link Utili</h1>
      <p class="page-header-sub">Federazioni, circoli, strumenti e risorse</p>
    </div>
  </section>

  <section class="section section-body">
    <div class="section-texture" aria-hidden="true"></div>
    <div class="container">

      <div class="links-grid">
        {linkCategories.map(cat => (
          <div class="card link-category">
            <h2>{cat.title}</h2>
            <ul>
              {cat.links.map(link => (
                <li>
                  <a href={link.url} target="_blank" rel="noopener">{link.name}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Page Header --- */
  .page-header {
    position: relative;
    padding: 5rem 0 3rem;
    overflow: hidden;
    text-align: center;
  }

  .page-header-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(212,160,84,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(107,58,42,0.12) 0%, transparent 50%),
      linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  }

  .page-header-decor {
    position: absolute;
    right: 10%;
    top: 50%;
    transform: translateY(-50%);
    font-size: clamp(120px, 18vw, 220px);
    color: rgba(212,160,84,0.06);
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  .page-header .container {
    position: relative;
    z-index: 1;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.5rem;
  }

  .page-header-sub {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .section-body {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(212,160,84,0.04) 0%, transparent 50%),
      var(--bg-primary);
  }

  .section-texture {
    position: absolute;
    inset: 0;
    opacity: 0.015;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 20px,
      rgba(212,160,84,1) 20px,
      rgba(212,160,84,1) 21px
    );
    pointer-events: none;
  }

  .section-body .container {
    position: relative;
    z-index: 1;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .link-category {
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  }

  .link-category:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.25);
    border-color: rgba(212,160,84,0.2);
  }

  .link-category h2 {
    font-size: 1.1rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .link-category ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .link-category a {
    font-size: 0.95rem;
    color: var(--text-secondary);
    display: block;
    padding: 0.3rem 0;
    transition: color 0.2s, padding-left 0.2s;
  }

  .link-category a:hover {
    color: var(--accent);
    padding-left: 0.5rem;
  }
</style>
