---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const tornei = await getCollection('tornei');
  return tornei.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.excerpt}>
  <article class="article-page">
    <div class="article-bg" aria-hidden="true"></div>
    <div class="article-texture" aria-hidden="true"></div>
    <div class="container article-container">
      <a href="/tornei" class="back-link">&larr; Tutti i tornei</a>
      <div class="article-head">
        <div class="article-accent-bar" aria-hidden="true"></div>
        <time>{new Date(entry.data.date).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
        <h1>{entry.data.title}</h1>
      </div>

      {(entry.data.vesus || entry.data.bando) && (
        <div class="torneo-links">
          {entry.data.vesus && (
            <a href={entry.data.vesus} target="_blank" rel="noopener" class="btn btn-primary btn-sm">
              Iscriviti su VeSuS
            </a>
          )}
          {entry.data.bando && (
            <a href={entry.data.bando} target="_blank" rel="noopener" class="btn btn-outline btn-sm">
              Scarica bando
            </a>
          )}
        </div>
      )}

      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    position: relative;
    overflow: hidden;
    padding: 5rem 0;
  }

  .article-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 10%, rgba(212,160,84,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 90%, rgba(107,58,42,0.08) 0%, transparent 50%),
      var(--bg-primary);
  }

  .article-texture {
    position: absolute;
    inset: 0;
    opacity: 0.012;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 20px,
      rgba(212,160,84,1) 20px,
      rgba(212,160,84,1) 21px
    );
    pointer-events: none;
  }

  .article-container {
    max-width: 750px;
    position: relative;
    z-index: 1;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    transition: color 0.2s, transform 0.2s;
  }

  .back-link:hover {
    color: var(--accent);
    transform: translateX(-3px);
  }

  .article-head {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .article-accent-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, var(--accent), var(--wood-dark));
    border-radius: 2px;
  }

  time {
    font-size: 0.85rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  h1 {
    margin: 0.75rem 0 0;
  }

  .torneo-links {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
  }

  .prose {
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .prose :global(h2) {
    color: var(--text-primary);
    margin: 2rem 0 1rem;
    font-size: 1.4rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.35rem;
  }

  .prose :global(strong) {
    color: var(--text-primary);
  }

  .prose :global(a) {
    color: var(--accent);
  }
</style>
