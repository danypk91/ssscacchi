---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allTornei = await getCollection('tornei');
const torneiByYear = allTornei
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .reduce((acc, t) => {
    const year = t.data.year;
    if (!acc[year]) acc[year] = [];
    acc[year].push(t);
    return acc;
  }, {} as Record<number, typeof allTornei>);

const years = Object.keys(torneiByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="Tornei" description="Archivio tornei del Circolo Scacchi Santa Sabina di Genova.">
  <section class="page-header">
    <div class="page-header-bg" aria-hidden="true"></div>
    <div class="page-header-decor" aria-hidden="true">&#9812;</div>
    <div class="container">
      <h1>Tornei</h1>
      <p class="page-header-sub">Archivio tornei organizzati dal circolo</p>
    </div>
  </section>

  <section class="section section-body">
    <div class="section-texture" aria-hidden="true"></div>
    <div class="container">

      <div class="search-box">
        <input type="text" id="torneo-search" placeholder="Cerca torneo..." autocomplete="off" />
      </div>
      <p id="no-results" class="no-results" style="display:none;">Nessun torneo trovato.</p>

      {years.map(year => (
        <div class="year-section">
          <h2 class="year-title">{year}</h2>
          <div class="tornei-list">
            {torneiByYear[Number(year)].map(t => (
              <a href={`/tornei/${t.id}`} class="card torneo-card">
                <time>{new Date(t.data.date).toLocaleDateString('it-IT', { day: 'numeric', month: 'long' })}</time>
                <h3>{t.data.title}</h3>
                <p>{t.data.excerpt}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Page Header --- */
  .page-header {
    position: relative;
    padding: 5rem 0 3rem;
    overflow: hidden;
    text-align: center;
  }

  .page-header-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(212,160,84,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(107,58,42,0.12) 0%, transparent 50%),
      linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  }

  .page-header-decor {
    position: absolute;
    right: 10%;
    top: 50%;
    transform: translateY(-50%);
    font-size: clamp(120px, 18vw, 220px);
    color: rgba(212,160,84,0.06);
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  .page-header .container {
    position: relative;
    z-index: 1;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.5rem;
  }

  .page-header-sub {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .section-body {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(212,160,84,0.04) 0%, transparent 50%),
      var(--bg-primary);
  }

  .section-texture {
    position: absolute;
    inset: 0;
    opacity: 0.015;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 20px,
      rgba(212,160,84,1) 20px,
      rgba(212,160,84,1) 21px
    );
    pointer-events: none;
  }

  .section-body .container {
    position: relative;
    z-index: 1;
  }

  .year-section {
    margin-bottom: 3rem;
  }

  .year-title {
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .tornei-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .torneo-card {
    display: block;
    color: inherit;
  }

  .torneo-card time {
    font-size: 0.8rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .torneo-card h3 {
    font-size: 1.15rem;
    margin: 0.3rem 0;
    transition: color 0.2s;
  }

  .torneo-card:hover h3 {
    color: var(--accent);
  }

  .torneo-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .search-box {
    margin-bottom: 2rem;
  }

  #torneo-search {
    width: 100%;
    max-width: 400px;
    padding: 0.75rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text-primary);
    font-size: 1rem;
    font-family: var(--font-body);
    transition: border-color 0.2s;
  }
  #torneo-search::placeholder {
    color: var(--text-muted);
  }
  #torneo-search:focus {
    outline: none;
    border-color: var(--accent);
  }

  .no-results {
    color: var(--text-muted);
    text-align: center;
    padding: 2rem 0;
  }
</style>

<script>
  function initSearch() {
    const input = document.getElementById('torneo-search') as HTMLInputElement;
    const noResults = document.getElementById('no-results')!;
    if (!input) return;

    const sections = document.querySelectorAll<HTMLElement>('.year-section');

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      let anyVisible = false;

      sections.forEach((section) => {
        const cards = section.querySelectorAll<HTMLElement>('.torneo-card');
        let sectionVisible = false;

        cards.forEach((card) => {
          const title = card.querySelector('h3')?.textContent?.toLowerCase() || '';
          const match = !q || title.includes(q);
          card.style.display = match ? '' : 'none';
          if (match) sectionVisible = true;
        });

        section.style.display = sectionVisible ? '' : 'none';
        if (sectionVisible) anyVisible = true;
      });

      noResults.style.display = anyVisible ? 'none' : '';
    });
  }

  initSearch();
  document.addEventListener('astro:after-swap', initSearch);
</script>
