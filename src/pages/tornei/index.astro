---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allTornei = await getCollection('tornei');
const torneiByYear = allTornei
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .reduce((acc, t) => {
    const year = t.data.year;
    if (!acc[year]) acc[year] = [];
    acc[year].push(t);
    return acc;
  }, {} as Record<number, typeof allTornei>);

const years = Object.keys(torneiByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="Tornei" description="Archivio tornei del Circolo Scacchi Santa Sabina di Genova.">
  <section class="page-header">
    <div class="page-header-bg" aria-hidden="true"></div>
    <div class="page-header-decor" aria-hidden="true">&#9812;</div>
    <div class="container">
      <h1>Tornei</h1>
      <p class="page-header-sub">Archivio tornei organizzati dal circolo</p>
    </div>
  </section>

  <section class="page-body">
    <div class="page-body-texture" aria-hidden="true"></div>
    <div class="container">

      <div class="page-search">
        <label for="torneo-search" class="visually-hidden">Cerca torneo</label>
        <input type="search" id="torneo-search" placeholder="Cerca torneo..." autocomplete="off" />
      </div>
      <p id="no-results" class="no-results" style="display:none;">Nessun torneo trovato.</p>

      {years.map(year => (
        <div class="year-section">
          <h2 class="year-title">{year}</h2>
          <div class="tornei-list">
            {torneiByYear[Number(year)].map(t => (
              <a href={`/tornei/${t.id}`} class="card torneo-card">
                <time>{new Date(t.data.date).toLocaleDateString('it-IT', { day: 'numeric', month: 'long' })}</time>
                <h3>{t.data.title}</h3>
                <p>{t.data.excerpt}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .year-section {
    margin-bottom: 3rem;
  }

  .year-title {
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .tornei-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .torneo-card {
    display: block;
    color: inherit;
  }

  .torneo-card time {
    font-size: 0.8rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .torneo-card h3 {
    font-size: 1.15rem;
    margin: 0.3rem 0;
    transition: color 0.2s;
  }

  .torneo-card:hover h3 {
    color: var(--accent);
  }

  .torneo-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .no-results {
    color: var(--text-muted);
    text-align: center;
    padding: 2rem 0;
  }
</style>

<script>
  function initSearch() {
    const input = document.getElementById('torneo-search') as HTMLInputElement;
    const noResults = document.getElementById('no-results')!;
    if (!input) return;

    const sections = document.querySelectorAll<HTMLElement>('.year-section');

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      let anyVisible = false;

      sections.forEach((section) => {
        const cards = section.querySelectorAll<HTMLElement>('.torneo-card');
        let sectionVisible = false;

        cards.forEach((card) => {
          const title = card.querySelector('h3')?.textContent?.toLowerCase() || '';
          const match = !q || title.includes(q);
          card.style.display = match ? '' : 'none';
          if (match) sectionVisible = true;
        });

        section.style.display = sectionVisible ? '' : 'none';
        if (sectionVisible) anyVisible = true;
      });

      noResults.style.display = anyVisible ? 'none' : '';
    });
  }

  initSearch();
  document.addEventListener('astro:after-swap', initSearch);
</script>