---
import BaseLayout from '../layouts/BaseLayout.astro';

const categorie = [
  { name: 'Aperture', icon: '&#9816;', desc: 'Trattati e repertori sulle aperture' },
  { name: 'Mediogioco', icon: '&#9815;', desc: 'Strategia, tattica e combinazioni' },
  { name: 'Finali', icon: '&#9814;', desc: 'Tecnica dei finali' },
  { name: 'Generali', icon: '&#9813;', desc: 'Manuali completi e didattica' },
  { name: 'Narrativa', icon: '&#9819;', desc: 'Romanzi e racconti a tema scacchistico' },
  { name: 'Raccolte', icon: '&#9812;', desc: 'Raccolte di partite commentate' },
];
---

<BaseLayout title="Biblioteca" description="Biblioteca scacchistica del Circolo Santa Sabina. Consultazione e prestito libri per i soci.">
  <section class="page-header">
    <div class="page-header-bg" aria-hidden="true"></div>
    <div class="page-header-decor" aria-hidden="true">&#9813;</div>
    <div class="container">
      <h1>Biblioteca</h1>
      <p class="page-header-sub">La nostra collezione scacchistica a disposizione dei soci</p>
    </div>
  </section>

  <section class="section section-body">
    <div class="section-texture" aria-hidden="true"></div>
    <div class="container">

      <div class="intro-card card">
        <div class="intro-grid">
          <div>
            <h2>Servizio di prestito</h2>
            <p>
              La biblioteca del circolo offre un servizio di <strong>consultazione e prestito</strong> libri
              per tutti i soci. La collezione comprende testi su aperture, mediogioco, finali, manuali generali,
              narrativa scacchistica e raccolte di partite commentate.
            </p>
          </div>
          <div class="rules-box">
            <h3>Regole</h3>
            <ul>
              <li>Un solo libro per volta</li>
              <li>Restituzione entro un mese</li>
              <li>Ritiro e restituzione negli orari indicati</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="schedule-banner">
        <span class="schedule-icon">&#128197;</span>
        <div>
          <strong>Orari del servizio biblioteca</strong>
          <p>Primo martedì e terzo venerdì di ogni mese, durante gli orari di apertura del circolo.</p>
        </div>
      </div>

      <h2 class="cat-title">Categorie disponibili</h2>
      <div class="cat-grid">
        {categorie.map(cat => (
          <div class="card cat-card">
            <div class="cat-icon" set:html={cat.icon} />
            <h3>{cat.name}</h3>
            <p>{cat.desc}</p>
          </div>
        ))}
      </div>

      <div class="contact-cta card">
        <h2>Vuoi prenotare un libro?</h2>
        <p>Contattaci via email indicando il titolo che ti interessa e ti confermeremo la disponibilità.</p>
        <a href="mailto:santasabinascacchi@gmail.com" class="btn btn-primary">
          Scrivi a santasabinascacchi@gmail.com
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Page Header --- */
  .page-header {
    position: relative;
    padding: 5rem 0 3rem;
    overflow: hidden;
    text-align: center;
  }

  .page-header-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(212,160,84,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(107,58,42,0.12) 0%, transparent 50%),
      linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  }

  .page-header-decor {
    position: absolute;
    right: 10%;
    top: 50%;
    transform: translateY(-50%);
    font-size: clamp(120px, 18vw, 220px);
    color: rgba(212,160,84,0.06);
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  .page-header .container {
    position: relative;
    z-index: 1;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.5rem;
  }

  .page-header-sub {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .section-body {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(212,160,84,0.04) 0%, transparent 50%),
      var(--bg-primary);
  }

  .section-texture {
    position: absolute;
    inset: 0;
    opacity: 0.015;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 20px,
      rgba(212,160,84,1) 20px,
      rgba(212,160,84,1) 21px
    );
    pointer-events: none;
  }

  .section-body .container {
    position: relative;
    z-index: 1;
  }

  .intro-card {
    margin-bottom: 2rem;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .intro-grid h2 {
    color: var(--accent);
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
  }

  .intro-grid p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .rules-box {
    background: var(--bg-secondary);
    border-radius: var(--radius);
    padding: 1.25rem;
  }

  .rules-box h3 {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .rules-box ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .rules-box li::before {
    content: '— ';
    color: var(--accent);
  }

  .schedule-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--accent-glow);
    border: 1px solid var(--wood-dark);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    margin-bottom: 3rem;
  }

  .schedule-icon {
    font-size: 1.8rem;
  }

  .schedule-banner strong {
    display: block;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .schedule-banner p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin: 0;
  }

  .cat-title {
    font-size: 1.3rem;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .cat-card {
    text-align: center;
    padding: 1.75rem 1.25rem;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
    position: relative;
    overflow: hidden;
  }

  .cat-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .cat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.25);
    border-color: rgba(212,160,84,0.2);
  }

  .cat-card:hover::after {
    opacity: 1;
  }

  .cat-icon {
    font-size: 2rem;
    color: var(--accent);
    margin-bottom: 0.75rem;
    transition: transform 0.3s;
  }

  .cat-card:hover .cat-icon {
    transform: scale(1.15);
  }

  .cat-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }

  .cat-card p {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .contact-cta {
    text-align: center;
    padding: 2.5rem;
  }

  .contact-cta h2 {
    color: var(--accent);
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
  }

  .contact-cta p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
