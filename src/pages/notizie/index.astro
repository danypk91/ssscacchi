---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notizie = (await getCollection('notizie'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Notizie" description="Tutte le notizie dal Circolo Scacchi Santa Sabina di Genova.">
  <section class="page-header">
    <div class="page-header-bg" aria-hidden="true"></div>
    <div class="page-header-decor" aria-hidden="true">&#9819;</div>
    <div class="container">
      <h1>Notizie</h1>
      <p class="page-header-sub">Tutte le novità dal circolo</p>
    </div>
  </section>

  <section class="section section-body">
    <div class="section-texture" aria-hidden="true"></div>
    <div class="container">

      <div class="news-list">
        {notizie.map(n => (
          <a href={`/notizie/${n.id}`} class="card news-item">
            <time>{new Date(n.data.date).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
            <h2>{n.data.title}</h2>
            <p>{n.data.excerpt}</p>
            <span class="read-more">Leggi tutto &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Page Header --- */
  .page-header {
    position: relative;
    padding: 5rem 0 3rem;
    overflow: hidden;
    text-align: center;
  }

  .page-header-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(212,160,84,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(107,58,42,0.12) 0%, transparent 50%),
      linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  }

  .page-header-decor {
    position: absolute;
    right: 10%;
    top: 50%;
    transform: translateY(-50%);
    font-size: clamp(120px, 18vw, 220px);
    color: rgba(212,160,84,0.06);
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  .page-header .container {
    position: relative;
    z-index: 1;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.5rem;
  }

  .page-header-sub {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .section-body {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(212,160,84,0.04) 0%, transparent 50%),
      var(--bg-primary);
  }

  .section-texture {
    position: absolute;
    inset: 0;
    opacity: 0.015;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 20px,
      rgba(212,160,84,1) 20px,
      rgba(212,160,84,1) 21px
    );
    pointer-events: none;
  }

  .section-body .container {
    position: relative;
    z-index: 1;
  }

  .news-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .news-item {
    display: block;
    color: inherit;
  }

  .news-item time {
    font-size: 0.8rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .news-item h2 {
    font-size: 1.35rem;
    margin: 0.4rem 0;
    transition: color 0.2s;
  }

  .news-item:hover h2 {
    color: var(--accent);
  }

  .news-item p {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .read-more {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 600;
  }
</style>
