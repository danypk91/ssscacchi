---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pagina non trovata">
  <section class="not-found">
    <div class="nf-bg" aria-hidden="true"></div>
    <div class="nf-pattern" aria-hidden="true"></div>
    <div class="container nf-content">
      <div class="nf-icon" aria-hidden="true">&#9812;</div>
      <div class="nf-code">404</div>
      <h1>Scacco matto!</h1>
      <p>La pagina che cerchi non esiste o è stata spostata.</p>
      <a href="/" class="btn btn-primary">Torna alla Home</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .nf-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 40%, rgba(212,160,84,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 100%, rgba(107,58,42,0.15) 0%, transparent 50%),
      var(--bg-primary);
  }

  .nf-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.02;
    background-image:
      linear-gradient(45deg, rgba(212,160,84,1) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(212,160,84,1) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(212,160,84,1) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(212,160,84,1) 75%);
    background-size: 40px 40px;
    background-position: 0 0, 0 20px, 20px -20px, -20px 0;
    pointer-events: none;
  }

  .nf-content {
    position: relative;
    z-index: 1;
  }

  .nf-icon {
    font-size: 5rem;
    color: var(--accent);
    opacity: 0.6;
    margin-bottom: 1rem;
    animation: nfBounce 3s ease-in-out infinite;
  }

  .nf-code {
    font-family: var(--font-heading);
    font-size: clamp(5rem, 12vw, 8rem);
    font-weight: 700;
    color: rgba(212,160,84,0.15);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  @keyframes nfBounce {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-8px) rotate(-5deg); }
    75% { transform: translateY(-4px) rotate(3deg); }
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }
</style>
