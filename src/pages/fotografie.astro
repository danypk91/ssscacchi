---
import BaseLayout from '../layouts/BaseLayout.astro';

const years = [2023, 2022, 2021, 2020, 2019, 2018, 2017, 2016, 2015, 2014, 2013, 2012, 2011, 2010];
---

<BaseLayout title="Fotografie" description="Gallerie fotografiche del Circolo Scacchi Santa Sabina.">
  <section class="page-header">
    <div class="page-header-bg" aria-hidden="true"></div>
    <div class="page-header-decor" aria-hidden="true">&#9815;</div>
    <div class="container">
      <h1>Fotografie</h1>
      <p class="page-header-sub">I nostri momenti più belli, anno per anno</p>
    </div>
  </section>

  <section class="section section-body">
    <div class="section-texture" aria-hidden="true"></div>
    <div class="container">

      <div class="gallery-grid">
        {years.map(year => (
          <a href={`https://santasabina.altervista.org/index.php/fotografie/category/${year}`} target="_blank" rel="noopener" class="card gallery-card">
            <div class="gallery-year">{year}</div>
            <p>Galleria fotografica anno {year}</p>
          </a>
        ))}
      </div>

      <div class="gallery-note">
        <p>Le gallerie fotografiche sono al momento ospitate sul sito precedente. Clicca su un anno per visualizzarle.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Page Header --- */
  .page-header {
    position: relative;
    padding: 5rem 0 3rem;
    overflow: hidden;
    text-align: center;
  }

  .page-header-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(212,160,84,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(107,58,42,0.12) 0%, transparent 50%),
      linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  }

  .page-header-decor {
    position: absolute;
    right: 10%;
    top: 50%;
    transform: translateY(-50%);
    font-size: clamp(120px, 18vw, 220px);
    color: rgba(212,160,84,0.06);
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  .page-header .container {
    position: relative;
    z-index: 1;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.5rem;
  }

  .page-header-sub {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .section-body {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(212,160,84,0.04) 0%, transparent 50%),
      var(--bg-primary);
  }

  .section-texture {
    position: absolute;
    inset: 0;
    opacity: 0.015;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 20px,
      rgba(212,160,84,1) 20px,
      rgba(212,160,84,1) 21px
    );
    pointer-events: none;
  }

  .section-body .container {
    position: relative;
    z-index: 1;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.25rem;
  }

  .gallery-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1rem;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  }

  .gallery-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    background: radial-gradient(circle at 50% 40%, rgba(212,160,84,0.08) 0%, transparent 70%);
    transition: opacity 0.3s;
  }

  .gallery-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.25);
    border-color: rgba(212,160,84,0.25);
  }

  .gallery-card:hover::before {
    opacity: 1;
  }

  .gallery-year {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.5rem;
    transition: transform 0.3s;
    position: relative;
  }

  .gallery-card:hover .gallery-year {
    transform: scale(1.12);
  }

  .gallery-card p {
    color: var(--text-muted);
    font-size: 0.85rem;
    position: relative;
  }

  .gallery-note {
    margin-top: 2.5rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
</style>
